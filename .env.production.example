# Production environment — copy to .env.production for local builds
# or set these in Vercel / Netlify dashboard (never commit secrets)

# ── Public URL (required for SEO / OG / sitemap / Play developer site) ───────
# No trailing slash — must match Play Console "Developer website" host exactly
VITE_GAME_URL=https://your-domain.com

# Support email (injected into dist/privacy.html at build)
VITE_SUPPORT_EMAIL=you@your-domain.com

# AdMob publisher ID (app-ads.txt — from AdMob → Account → Publisher ID)
VITE_ADMOB_PUBLISHER_ID=pub-XXXXXXXXXXXXXXXX

# ── Ads (freemium) ───────────────────────────────────────────────────────────
VITE_AD_PROVIDER=google
VITE_AD_TEST_MODE=false

# Real-money purchases — set true when Play/Stripe IAP is ready
VITE_IAP_ENABLED=false

# AdMob — Android / iOS native (Capacitor)
VITE_ADMOB_APP_ID_ANDROID=ca-app-pub-XXXXXXXX~YYYYYYYY
VITE_ADMOB_APP_ID_IOS=ca-app-pub-XXXXXXXX~YYYYYYYY
VITE_ADMOB_BANNER_ANDROID=ca-app-pub-XXXXXXXX/ZZZZZZZZ
VITE_ADMOB_BANNER_IOS=ca-app-pub-XXXXXXXX/ZZZZZZZZ
VITE_ADMOB_INTERSTITIAL_ANDROID=ca-app-pub-XXXXXXXX/ZZZZZZZZ
VITE_ADMOB_INTERSTITIAL_IOS=ca-app-pub-XXXXXXXX/ZZZZZZZZ
VITE_ADMOB_REWARDED_ANDROID=ca-app-pub-XXXXXXXX/ZZZZZZZZ
VITE_ADMOB_REWARDED_IOS=ca-app-pub-XXXXXXXX/ZZZZZZZZ

# AdSense — web PWA banner
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_BANNER_SLOT=XXXXXXXXXX

# Ad Manager — web interstitial / rewarded (optional)
# VITE_ADMANAGER_INTERSTITIAL_WEB=/XXXXXXXX/neon_interstitial
# VITE_ADMANAGER_REWARDED_WEB=/XXXXXXXX/neon_rewarded

# Google UMP consent — enable for EEA / UK users
VITE_AD_CONSENT=true

# ── In-app purchases ─────────────────────────────────────────────────────────

# RevenueCat — native Android / iOS (public SDK keys only)
VITE_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxx
# VITE_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxx

# Stripe — web PWA checkout (Payment Link base URL)
VITE_STRIPE_CHECKOUT_URL=https://buy.stripe.com/xxxxxxxx

# ── Server-only (Vercel / Netlify — NOT prefixed with VITE_) ─────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_UNLOCK_SECRET=...   # optional; defaults to STRIPE_WEBHOOK_SECRET
