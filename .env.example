# Public URL for share links, Open Graph, canonical, and sitemap (no trailing slash)
# VITE_GAME_URL=https://yourname.github.io/Neon-Nexus-Bullet-Time-Brickbreaker

# VITE_SUPPORT_EMAIL=you@your-domain.com
# VITE_ADMOB_PUBLISHER_ID=pub-XXXXXXXXXXXXXXXX

# Ad provider — demo | google | noop
VITE_AD_PROVIDER=demo

# Real-money IAP (Remove Ads, gem packs, Premium). false = ads-only launch.
# VITE_IAP_ENABLED=true

# Use Google test ad units (keep true until you ship real IDs)
VITE_AD_TEST_MODE=true

# --- AdMob (Android / iOS) — replace with your app & unit IDs ---
# VITE_ADMOB_APP_ID_ANDROID=ca-app-pub-XXXXXXXX~YYYYYYYY
# VITE_ADMOB_APP_ID_IOS=ca-app-pub-XXXXXXXX~YYYYYYYY
# VITE_ADMOB_BANNER_ANDROID=ca-app-pub-XXXXXXXX/ZZZZZZZZ
# VITE_ADMOB_BANNER_IOS=ca-app-pub-XXXXXXXX/ZZZZZZZZ
# VITE_ADMOB_INTERSTITIAL_ANDROID=ca-app-pub-XXXXXXXX/ZZZZZZZZ
# VITE_ADMOB_INTERSTITIAL_IOS=ca-app-pub-XXXXXXXX/ZZZZZZZZ
# VITE_ADMOB_REWARDED_ANDROID=ca-app-pub-XXXXXXXX/ZZZZZZZZ
# VITE_ADMOB_REWARDED_IOS=ca-app-pub-XXXXXXXX/ZZZZZZZZ

# --- AdSense (web banner) ---
# VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# VITE_ADSENSE_BANNER_SLOT=XXXXXXXXXX
# Optional NEXT_PUBLIC_* mirrors for React shell hydration (same values):
# NEXT_PUBLIC_AD_PROVIDER=google
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-...
# NEXT_PUBLIC_ADSENSE_BANNER_SLOT=...
# NEXT_PUBLIC_SHELL_ADS=1

# --- Ad Manager (web interstitial / rewarded — optional) ---
# VITE_ADMANAGER_INTERSTITIAL_WEB=/XXXXXXXX/neon_interstitial
# VITE_ADMANAGER_REWARDED_WEB=/XXXXXXXX/neon_rewarded

# Request Google UMP consent on boot (EEA / UK)
# VITE_AD_CONSENT=true

# --- RevenueCat (native IAP) ---
# VITE_REVENUECAT_ANDROID_KEY=goog_xxxxxxxx
# VITE_REVENUECAT_IOS_KEY=appl_xxxxxxxx

# --- Stripe (web PWA checkout) ---
# VITE_STRIPE_CHECKOUT_URL=https://buy.stripe.com/xxxxxxxx

# --- Firebase Auth (cloud sync) ---
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_API_BASE=

# --- Server-only (Vercel — never expose to client) ---
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
# MONGODB_DB=neon_nexus
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
